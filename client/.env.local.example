# Copy this file to .env.local and fill in your values
# All VITE_* vars have been renamed to NEXT_PUBLIC_* for Next.js

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=

# Server-side Firebase Admin (do NOT expose with NEXT_PUBLIC_)
# Option A: JSON string
FIREBASE_SERVICE_ACCOUNT=

# Option B: split credentials
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=
FIREBASE_DATABASE_URL=

# Optional server-side Cloudinary keys (for signed/server uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Cloudflare CDN (recommended in production)
# Example: https://cdn.abjeetravel.com
NEXT_PUBLIC_CDN_URL=

# Cloudflare R2 public asset hosting (for /public image/video files)
# Example: https://pub-xxxxxxxx.r2.dev
NEXT_PUBLIC_R2_ASSET_BASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Upstash Redis (optional but recommended for shared cache/locks across instances)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Alternative generic Redis REST variable names supported by the app
REDIS_REST_URL=
REDIS_REST_TOKEN=
