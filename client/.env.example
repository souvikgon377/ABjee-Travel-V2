# Client Environment Variables Example
# Copy this file to .env for local development

# Backend server URL (use localhost for local development)
VITE_SERVER_URL=http://localhost:5000

# App configuration
VITE_APP_NAME=ABjee Travel
VITE_APP_VERSION=1.0.0

# Feature flags
VITE_ENABLE_CHAT=true
VITE_ENABLE_TRAVEL_PARTNERS=true
VITE_ENABLE_SUBSCRIPTIONS=true

# Development settings (set to false in production)
VITE_DEBUG_MODE=true

# Firebase Configuration
# Get these from Firebase Console > Project Settings > Your apps
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id
VITE_FIREBASE_DATABASE_URL=https://your_project-default-rtdb.region.firebasedatabase.app

# Cloudinary Configuration
# Get these from Cloudinary Console > Settings
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_API_KEY=your_api_key
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
