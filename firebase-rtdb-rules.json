{
  "rules": {
    "chatrooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomId": {
        ".read": "auth != null",
        ".write": "auth != null && (data.child('createdBy').val() === auth.uid || root.child('chatrooms').child($roomId).child('participants').val().contains(auth.uid))"
      }
    },
    "status": {
      ".read": "auth != null",
      ".indexOn": ["isOnline", "lastSeen"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "lastSeen": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "typing": {
      "$roomId": {
        "$uid": {
          ".read": "auth != null",
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}

