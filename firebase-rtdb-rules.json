{
  "rules": {
    "chatrooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["createdAt", "name", "isPrivate", "memberCount"],
      "$roomId": {
        "messages": {
          ".indexOn": ["timestamp", "userId"]
        },
        "participants": {
          ".indexOn": ["joinedAt"]
        }
      }
    },
    "analytics": {
      ".read": "auth != null",
      "pageViews": {
        ".read": true,
        ".write": true
      }
    },
    "status": {
      ".read": "auth != null",
      ".indexOn": ["isOnline", "lastSeen"],
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "lastSeen": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth != null && auth.uid == $uid"
      }
    },
    "typing": {
      "$roomId": {
        ".read": "auth != null",
        "$uid": {
          ".write": "auth != null && auth.uid == $uid"
        }
      }
    },
    ".read": false,
    ".write": false
  }
}

